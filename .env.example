# Active profile: local or work
CODEX_PROXY_PROFILE=local

# Logging
LOG_LEVEL=INFO

# -----------------------
# Local profile
# -----------------------
LOCAL_PROXY_HOST=127.0.0.1
LOCAL_PROXY_PORT=8765
LOCAL_PROXY_STATIC_API_KEY=local-dev-proxy-key

LOCAL_UPSTREAM_BASE_URL=https://api.openai.com/v1
LOCAL_VERIFY_SSL=true
LOCAL_UPSTREAM_API_KEY=

LOCAL_OAUTH_TOKEN_ENDPOINT=
LOCAL_OAUTH_CLIENT_ID=
LOCAL_OAUTH_CLIENT_SECRET=
LOCAL_OAUTH_SCOPE=
LOCAL_OAUTH_REFRESH_BUFFER_MINUTES=5

LOCAL_DEFAULT_MAX_TOKENS=32768
LOCAL_DEFAULT_MAX_OUTPUT_TOKENS=32768

# Format: external_model=internal_model,external_model2=internal_model2
LOCAL_MODEL_MAPPING=gpt-5.3-codex=internal-gpt5-codex

LOCAL_CODEX_MODEL_PROVIDER=codex-launcher-proxy
LOCAL_CODEX_MODEL=gpt-5.3-codex
LOCAL_CODEX_ENV_KEY=CODEX_PROXY_API_KEY

# -----------------------
# Work profile
# -----------------------
WORK_PROXY_HOST=127.0.0.1
WORK_PROXY_PORT=8765
WORK_PROXY_STATIC_API_KEY=

WORK_UPSTREAM_BASE_URL=
WORK_VERIFY_SSL=true
WORK_UPSTREAM_API_KEY=

WORK_OAUTH_TOKEN_ENDPOINT=
WORK_OAUTH_CLIENT_ID=
WORK_OAUTH_CLIENT_SECRET=
WORK_OAUTH_SCOPE=
WORK_OAUTH_REFRESH_BUFFER_MINUTES=5

WORK_DEFAULT_MAX_TOKENS=32768
WORK_DEFAULT_MAX_OUTPUT_TOKENS=32768
WORK_MODEL_MAPPING=

WORK_CODEX_MODEL_PROVIDER=codex-launcher-proxy
WORK_CODEX_MODEL=gpt-5.3-codex
WORK_CODEX_ENV_KEY=CODEX_PROXY_API_KEY
